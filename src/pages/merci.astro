---
// Page de confirmation après envoi du formulaire de contact (Netlify Forms)
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Demande envoyée"
	description="Votre demande a bien été envoyée à VILAS ELEC. Nous vous recontactons sous 24 à 48h pour votre projet électrique."
>
	<div class="min-h-[70vh] flex items-center justify-center px-4 py-24 pt-32 bg-gradient-to-br from-blue-50 to-white">
		<div class="max-w-xl w-full bg-white rounded-2xl shadow-xl p-8 md:p-12 text-center" data-aos="zoom-in">
			<!-- Icône de succès -->
			<div class="mx-auto mb-6 flex items-center justify-center w-20 h-20 rounded-full bg-green-100">
				<svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
				</svg>
			</div>

			<h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
				Merci pour votre demande !
			</h1>
			<p class="text-lg text-gray-600 mb-2">
				Votre message a bien été transmis à <strong>VILAS ELEC</strong>.
			</p>
			<p class="text-gray-600 mb-8">
				Nous revenons vers vous <strong>sous 24 à 48h</strong> pour étudier votre projet.
				Pour une urgence, n'hésitez pas à nous appeler directement.
			</p>

			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a
					href="/"
					class="bg-blue-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-700 transition-all duration-300 shadow-lg hover:scale-105 transform"
				>
					Retour à l'accueil
				</a>
				<a
					href="/realisations"
					class="bg-yellow-400 text-blue-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition-all duration-300 shadow-lg hover:scale-105 transform"
				>
					Voir nos réalisations
				</a>
			</div>
		</div>
	</div>
</Layout>
