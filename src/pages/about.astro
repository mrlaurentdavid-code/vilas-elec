---
// Page À propos - Vilas Elec
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="À propos"
	description="Vilas Elec - Électricien Certifié par Legrand à Saint-Vit (25410). Expertise en domotique, maison connectée et électricité générale. Membre du réseau des Électriciens Certifiés."
	keywords="électricien Saint-Vit, Legrand, certifié, Netatmo, Céliane, Drivia, domotique"
>
	<!-- Hero Section -->
	<div class="relative bg-gradient-to-br from-blue-600 to-steel-700 text-white py-20 pt-32">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center" data-aos="fade-up">
				<h1 class="text-4xl md:text-5xl font-bold mb-6">
					À Propos de Vilas Elec
				</h1>
				<p class="text-xl md:text-2xl text-blue-100 max-w-3xl mx-auto">
					Votre électricien de confiance à Saint-Vit, certifié par Legrand
				</p>
			</div>
		</div>
	</div>

	<!-- Section Présentation -->
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
		<div class="grid md:grid-cols-2 gap-12 items-center">
			<!-- Texte -->
			<div data-aos="fade-right">
				<h2 class="text-3xl md:text-4xl font-bold mb-6 text-gray-800">
					Qui sommes-nous ?
				</h2>
				<div class="space-y-4 text-gray-600 leading-relaxed">
					<p>
						<strong class="text-gray-800">VILAS ELEC</strong> est une entreprise professionnelle de l'électricité au savoir-faire reconnu, basée à <strong>Saint-Vit (25410)</strong> dans le Doubs, et membre du réseau des <strong>Électriciens Certifiés par Legrand</strong>.
					</p>
					<p>
						Notre entreprise est apte à vous accompagner et à vous proposer une offre complète, de la domotique connectée aux installations électriques traditionnelles, tout en respectant les exigences de la <strong>norme NF C 15-100</strong> qui concerne les locaux d'habitation.
					</p>
					<p>
						Vous êtes à la recherche d'un artisan électricien à Saint-Vit ou dans les alentours pour réaliser des travaux d'ordre <strong>personnel</strong> (appartement, maison) ou <strong>professionnel</strong> (commerces, bureaux d'entreprises) ? Contactez dès à présent VILAS ELEC pour avancer sur votre projet d'électricité.
					</p>
				</div>
			</div>

			<!-- Image/Badge -->
			<div data-aos="fade-left">
				<div class="bg-gradient-to-br from-blue-50 to-blue-100 p-8 rounded-2xl shadow-xl">
					<div class="text-center">
						<div class="inline-block bg-blue-600 text-white p-6 rounded-full mb-6">
							<svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
							</svg>
						</div>
						<h3 class="text-2xl font-bold text-gray-800 mb-4">Électricien Certifié</h3>
						<p class="text-gray-600 mb-6">Membre du réseau des Électriciens Certifiés par Legrand</p>
						<div class="flex flex-wrap gap-3 justify-center">
							<span class="bg-white px-4 py-2 rounded-full text-sm font-semibold text-gray-700 shadow">Norme NF C 15-100</span>
							<span class="bg-white px-4 py-2 rounded-full text-sm font-semibold text-gray-700 shadow">Legrand</span>
							<span class="bg-white px-4 py-2 rounded-full text-sm font-semibold text-gray-700 shadow">Netatmo</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Section Expertise -->
	<div class="bg-gray-50 py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16" data-aos="fade-up">
				<h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-800">
					Expertise et Compétences Multiples
				</h2>
				<p class="text-xl text-gray-600 max-w-3xl mx-auto">
					VILAS ELEC est signataire d'un engagement pour faire partie du dispositif Électriciens Certifiés par Legrand
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
				<!-- Gamme Céliane -->
				<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300" data-aos="fade-up" data-aos-delay="100">
					<div class="text-4xl mb-4">🎛️</div>
					<h3 class="text-2xl font-bold mb-3 text-gray-800">Céliane</h3>
					<p class="text-gray-600">
						Interrupteurs et prises design, pratiques et connectés pour embellit et faciliter votre quotidien.
					</p>
				</div>

				<!-- Gamme Drivia -->
				<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300" data-aos="fade-up" data-aos-delay="200">
					<div class="text-4xl mb-4">📊</div>
					<h3 class="text-2xl font-bold mb-3 text-gray-800">Drivia</h3>
					<p class="text-gray-600">
						Tableau électrique intelligent pour gérer vos consommations d'énergie en temps réel.
					</p>
				</div>

				<!-- Gamme Netatmo -->
				<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300" data-aos="fade-up" data-aos-delay="300">
					<div class="text-4xl mb-4">🏠</div>
					<h3 class="text-2xl font-bold mb-3 text-gray-800">Netatmo</h3>
					<p class="text-gray-600">
						Solutions connectées pour le chauffage, la sécurité et le confort de votre maison.
					</p>
				</div>

				<!-- Multimédia -->
				<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300" data-aos="fade-up" data-aos-delay="400">
					<div class="text-4xl mb-4">📡</div>
					<h3 class="text-2xl font-bold mb-3 text-gray-800">Multimédia</h3>
					<p class="text-gray-600">
						Réseau Wi-Fi performant, prises RJ45 pour une connexion optimale dans toute la maison.
					</p>
				</div>

				<!-- Visiophone -->
				<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300" data-aos="fade-up" data-aos-delay="500">
					<div class="text-4xl mb-4">📹</div>
					<h3 class="text-2xl font-bold mb-3 text-gray-800">Visiophone Connecté</h3>
					<p class="text-gray-600">
						Sonnettes et visiophones connectés pour voir qui sonne, même à distance.
					</p>
				</div>

				<!-- Recharge électrique -->
				<div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300" data-aos="fade-up" data-aos-delay="600">
					<div class="text-4xl mb-4">🔌</div>
					<h3 class="text-2xl font-bold mb-3 text-gray-800">GREEN'UP</h3>
					<p class="text-gray-600">
						Bornes de recharge pour véhicules électriques, installation professionnelle.
					</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Section Accompagnement Legrand -->
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
		<div class="bg-gradient-to-r from-blue-600 to-steel-700 rounded-2xl p-8 md:p-12 text-white shadow-2xl" data-aos="zoom-in">
			<div class="max-w-4xl mx-auto text-center">
				<h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
					Accompagné par Legrand
				</h2>
				<div class="space-y-4 text-lg text-white">
					<p>
						L'entreprise VILAS ELEC, située à Saint-Vit, est tenue en permanence <strong class="text-yellow-300">informée des tendances et des évolutions</strong> du marché de l'électricité ainsi que des nouveautés produits Legrand.
					</p>
					<p>
						L'entreprise VILAS ELEC est ainsi capable de <strong class="text-yellow-300">vous conseiller au mieux</strong> et, si besoin, de faire évoluer votre installation électrique dans le temps.
					</p>
					<p>
						En tant que professionnel, l'entreprise VILAS ELEC est à même de vous faire une <strong class="text-yellow-300">démonstration des solutions</strong> qui vous intéressent dans le showroom Innoval de Legrand le plus proche de chez vous.
					</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Section Nos Valeurs -->
	<div class="bg-gray-50 py-20">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-16" data-aos="fade-up">
				<h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-800">
					Nos Valeurs
				</h2>
			</div>

			<div class="grid md:grid-cols-4 gap-8">
				<!-- Valeur 1 -->
				<div class="text-center" data-aos="fade-up" data-aos-delay="100">
					<div class="bg-blue-600 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-2 text-gray-800">Expertise</h3>
					<p class="text-gray-600">Savoir-faire reconnu et certification Legrand</p>
				</div>

				<!-- Valeur 2 -->
				<div class="text-center" data-aos="fade-up" data-aos-delay="200">
					<div class="bg-blue-600 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-2 text-gray-800">Sécurité</h3>
					<p class="text-gray-600">Respect strict de la norme NF C 15-100</p>
				</div>

				<!-- Valeur 3 -->
				<div class="text-center" data-aos="fade-up" data-aos-delay="300">
					<div class="bg-blue-600 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-2 text-gray-800">Innovation</h3>
					<p class="text-gray-600">Solutions connectées et domotique moderne</p>
				</div>

				<!-- Valeur 4 -->
				<div class="text-center" data-aos="fade-up" data-aos-delay="400">
					<div class="bg-blue-600 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4">
						<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5"></path>
						</svg>
					</div>
					<h3 class="text-xl font-bold mb-2 text-gray-800">Satisfaction</h3>
					<p class="text-gray-600">Écoute, conseil et accompagnement personnalisé</p>
				</div>
			</div>
		</div>
	</div>

	<!-- CTA Section -->
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
		<div class="bg-gradient-to-r from-yellow-400 to-yellow-500 rounded-2xl p-8 md:p-12 text-center" data-aos="zoom-in">
			<h2 class="text-3xl md:text-4xl font-bold mb-6 text-blue-900">
				Prêt à démarrer votre projet ?
			</h2>
			<p class="text-xl text-blue-800 mb-8 max-w-2xl mx-auto">
				Contactez VILAS ELEC à Saint-Vit pour un devis gratuit et personnalisé
			</p>
			<a
				href="/contact"
				class="inline-block bg-blue-900 text-white px-10 py-4 rounded-lg font-bold text-lg hover:bg-blue-800 transition-all duration-300 shadow-xl hover:scale-105 transform"
			>
				Obtenir un devis gratuit
			</a>
		</div>
	</div>
</Layout>
